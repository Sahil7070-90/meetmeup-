# ══════════════════════════════════════════
# STRANIQ — Environment Variables
# Copy this file to .env and fill values
# ══════════════════════════════════════════

# ── Server ──────────────────────────────
PORT=3000
NODE_ENV=production

# ── Security ────────────────────────────
JWT_SECRET=change_this_to_random_64_char_string
ADMIN_SECRET_PATH=your-secret-admin-path-here
# Admin URL will be: /your-secret-admin-path-here
# Example: /xk92mq-admin-panel (share with nobody!)

# ── Email OTP (Gmail SMTP) ───────────────
# 1. Go to Google Account → Security → 2-Step Verification → App Passwords
# 2. Generate password for "Mail"
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM=Straniq <your-gmail@gmail.com>

# ── Phone OTP (Fast2SMS - India) ────────
# Sign up free at fast2sms.com → Get API key
# Free 50 SMS on signup
FAST2SMS_API_KEY=your-fast2sms-api-key

# ── Content Moderation (Sightengine) ────
# Free 500 checks/month at sightengine.com
# Sign up → API → Get api_user and api_secret
SIGHTENGINE_USER=your-sightengine-user
SIGHTENGINE_SECRET=your-sightengine-secret

# ── Payment (Razorpay) ──────────────────
# dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
RAZORPAY_SECRET=xxxxxxxxxxxxxxxx

# ── Admin ────────────────────────────────
ADMIN_PASSWORD=change-this-strong-password
